APP_NAME="OctoberCMS Headless Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Disable CMS module — this is the KEY setting!
CMS_DISABLE_MODULE=true

DB_CONNECTION=sqlite
# For SQLite just create database/database.sqlite and leave DB_DATABASE blank
# DB_DATABASE=/absolute/path/to/database.sqlite

# Or use MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=october_headless
# DB_USERNAME=root
# DB_PASSWORD=

# Frontend URL for CORS (production)
FRONTEND_URL=http://localhost:5173

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
